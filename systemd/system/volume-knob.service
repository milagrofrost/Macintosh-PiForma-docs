[Unit]
Description=GPIO Volume Knob
After=graphical.target

[Service]
Type=simple
User=frost
Environment=HOME=/home/frost
Environment=XDG_RUNTIME_DIR=/run/user/1000
WorkingDirectory=/home/frost
ExecStart=/usr/bin/python3 /usr/local/bin/volume_knob.py
Restart=always
RestartSec=1

[Install]
WantedBy=graphical.target
